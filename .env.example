# AGL.ai Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# CORE CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# DATABASE (MySQL via Drizzle ORM)
# ============================================
DATABASE_URL=mysql://user:password@localhost:3306/aglai_db

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-here-change-this
ADMIN_PASSWORD=#AllOfThem-3301
RECOVERY_CODE=Merleoskyn

# ============================================
# FREE LLM PROVIDERS (At least one required)
# ============================================

# GitHub API (FREE - Uses your GitHub token for LLM access)
# This gives you access to GitHub Models API (Phi-3, Llama 3, Mistral, etc.)
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here
GITHUB_API_KEY=your_github_token_here

# Groq (FREE tier - 60 req/min, Llama 3.3 70B, Mixtral)
# Get key at: https://console.groq.com
GROQ_API_KEY=

# Together AI (FREE credits on signup - Llama, Mistral, Qwen)
# Get key at: https://api.together.xyz
TOGETHER_API_KEY=

# HuggingFace (FREE 10k req/month - Thousands of open models)
# Get token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=
HUGGINGFACE_API_KEY=

# Google Gemini (FREE tier - 15 req/min, gemini-1.5-flash)
GEMINI_API_KEY=

# ============================================
# OAUTH (Optional - for Manus OAuth)
# ============================================
OAUTH_SERVER_URL=https://api.manus.ai
VITE_OAUTH_PORTAL_URL=https://manus.im

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_APP_ID=PqpbSuTc7zoQqjcx4gU9DV
VITE_APP_TITLE=AGL.ai
VITE_APP_LOGO=https://files.manuscdn.com/user_upload_by_module/web_dev_logo/310519663375123518/ohwsjrsRlYbUPUjt.png
VITE_ANALYTICS_ENDPOINT=https://manus-analytics.com
VITE_ANALYTICS_WEBSITE_ID=82c580ad-e836-40d1-8284-604fbdd3b2d8
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai
VITE_FRONTEND_FORGE_API_KEY=Y6tW8eKyp7hGChFrL6RR7K

# ============================================
# TELEGRAM BOT (Admin Controls)
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here
TELEGRAM_BOT_ENABLED=true

# ============================================
# PAYMENT (Monero/XMR)
# ============================================
MONERO_RECEIVER_ADDRESS=8BbApiMBHsPVKkLEP4rVbST6CnSb3LW2gXygngCi5MGiBuwAFh6bFEzT3UTuFCkLHtyHnrYNnHycdaGb2Kgkkmw8jViCdB6
MONERO_PRICING_STARTER=0.05
MONERO_PRICING_PROFESSIONAL=0.18
MONERO_PRICING_ELITE=0.30

# ============================================
# VERCEL DEPLOYMENT
